
# ====== Global ======
PROJECT_NAME=open-positions-tracker
NODE_ENV=development
TZ=Asia/Kolkata

# ====== Postgres (Docker) ======
POSTGRES_DB=opt_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5555

# ====== API ======
API_PORT=8080
JWT_SECRET=change_me_super_secret
BCRYPT_SALT_ROUNDS=10
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
LOG_LEVEL=info

# ====== Email (Nodemailer) ======
EMAIL_FROM="OPT Bot <no-reply@opt.local>"
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
WEEKEND_SUMMARY_TO=mgmt@example.com

# ====== PGAdmin (optional) ======
PGADMIN_DEFAULT_EMAIL=admin@local.local
PGADMIN_DEFAULT_PASSWORD=admin123
PGADMIN_PORT=5050


# OIDC / SSO (Microsoft Entra ID example)
OIDC_ISSUER=https://login.microsoftonline.com/<TENANT_ID>/v2.0
OIDC_CLIENT_ID=<app_client_id>
OIDC_CLIENT_SECRET=<app_client_secret>
OIDC_REDIRECT_URI=http://localhost:8080/api/v1/auth/sso/callback
OIDC_ROLE_CLAIM=roles
OIDC_DEFAULT_ROLE=VIEWER
FRONTEND_REDIRECT=http://localhost:5173

