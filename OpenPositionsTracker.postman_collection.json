{
  "info": {
    "name": "Open Positions Tracker - API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/auth/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\"email\": \"admin@opt.local\", \"password\": \"Admin@123\"}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const json = pm.response.json();",
              "pm.collectionVariables.set('token', json.token);"
            ]
          }
        }
      ]
    },
    {
      "name": "Config - Columns",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/config/columns",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "config",
            "columns"
          ]
        }
      }
    },
    {
      "name": "Demands - List",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/demands?limit=50",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "demands"
          ],
          "query": [
            {
              "key": "limit",
              "value": "50"
            }
          ]
        }
      }
    },
    {
      "name": "Demands - Create (mock shape)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/demands",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "demands"
          ]
        },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"priority\": \"Medium\",\n  \"type\": \"Pipeline - New Work\",\n  \"client\": \"Zuci Systems\",\n  \"project\": \"Data Lake POC\",\n  \"probability\": 60,\n  \"startDate\": \"2026-03-20\",\n  \"role\": \"Data Engineer\",\n  \"level\": \"Senior\",\n  \"location\": \"Remote\",\n  \"skills\": \"Spark, Delta Lake\",\n  \"status\": \"Open\"\n}"
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "demand_id",
      "value": ""
    }
  ]
}